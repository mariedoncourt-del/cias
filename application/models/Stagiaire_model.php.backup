  public function modifier_stagiairessss($nom_stagiaire,$prenom_stagiaire,$date_naissance,$numero_secu,$tel,$mail,$diplome)
  {
    $query = $this->db->query(
      "UPDATE Stagiaire SET date_naissance = ?, numero_secu = ?, tel = ?, mail = ?, diplome = ? WHERE nom_stagiaire LIKE ? AND prenom_stagiaire LIKE ?",
      array($date_naissance, $numero_secu, $tel, $mail, $diplome, $nom_stagiaire, $prenom_stagiaire)
    );
    return $query;
  }

  public function parcours_facture()
  {
    $query = $this->db->query("SELECT * FROM Facture WHERE nom_stagiaire NOT LIKE 'FERTON' AND nom_stagiaire NOT LIKE 'ROLLIN' AND YEAR(date_facture) LIKE '2024' ORDER BY num_facture ASC");
    return $query->result();
  }

