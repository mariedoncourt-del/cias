  public function modifier_accueil($id,$nom_accueil,$interlocuteur,$adresse,$code_postal,$ville,$tel,$mail)
  {
    if($id)
    {
      if(!$nom_accueil)
        $nom_accueil = '';
      if(!$interlocuteur)
        $interlocuteur = '';
      if(!$adresse)
        $adresse = '';
      if(!$code_postal)
        $code_postal = '';
      if(!$ville)
        $ville = '';
      if(!$tel)
        $tel = '';
      if(!$mail)
        $mail = '';
      
      $q = $this->db->query(
        "UPDATE Accueil SET nom_accueil = ?, interlocuteur = ?, adresse = ?, code_postal = ?, ville = ?, tel = ?, mail = ? WHERE num_accueil = ?",
        array($nom_accueil, $interlocuteur, $adresse, $code_postal, $ville, $tel, $mail, $id)
      );
      return $q;
    }
  }

  // Fonction utilitaire pour échapper les données d'entrée
  private function escape_data($data)
  {
    if (is_array($data)) {
      foreach ($data as $key => $value) {
        $data[$key] = $this->db->escape_str($value);
      }
      return $data;
    } else {
      return $this->db->escape_str($data);
    }
  }
}

