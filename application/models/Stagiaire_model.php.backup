  public function verifier_date_signature($nom_stagiaire, $prenom_stagiaire, $id_formation)
  {
    $query = $this->db->query(
      "SELECT date_signature_1 FROM Emargement WHERE nom_stagiaire LIKE ? AND prenom_stagiaire LIKE ? AND id_formation LIKE ?",
      array($nom_stagiaire, $prenom_stagiaire, $id_formation)
    );
    foreach($query->result() as $row)
    {
      if(empty($row->date_signature_1))
      {
        return true;
      }
      else{
        return false;
      }
    }
  }

