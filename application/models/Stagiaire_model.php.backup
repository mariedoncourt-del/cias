  public function verifier_date_convention($champ,$date,$nom_formateur,$prenom_formateur)
  {
    // Note: Cette requête utilise un nom de colonne dynamique, ce qui nécessite une approche différente
    $champ = $this->db->escape_str($champ);
    $query = $this->db->query(
      "SELECT ".$champ." FROM Convention WHERE ".$champ." LIKE ? AND nom_formateur LIKE ? AND prenom_formateur LIKE ?",
      array($date, $nom_formateur, $prenom_formateur)
    );
    if($query->num_rows()>0)
    {
      return "Vrai";
    }
    else{
      return "Faux";
    }
  }

