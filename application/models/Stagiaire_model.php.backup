  public function modifier_signature($nomstagiaire,$prenomstagiaire,$signature1,$signature2,$signature3,$signature4,$signature5,$signature6,$signature7,$signature8,$signature9,$signature10,$signature11,$signature12,$signature13,$signature14,$signature15,$signature16,$signature17,$signature18,$signature19,$signature20,$signatureformateur1,$signatureformateur2,$signatureformateur3,$signatureformateur4,$signatureformateur5,$signatureformateur6,$signatureformateur7,$signatureformateur8,$signatureformateur9,$signatureformateur10, $signatureformateur11,$signatureformateur12,$signatureformateur13,$signatureformateur14,$signatureformateur15,$signatureformateur16,$signatureformateur17,$signatureformateur18,$signatureformateur19,$signatureformateur20)
  {
    $query = $this->db->query(
      "UPDATE Emargement SET signature_1 = ?, signature_2 = ?, signature_3 = ?, signature_4 = ?, signature_5 = ?, signature_6 = ?, signature_7 = ?, signature_8 = ?, signature_9 = ?, signature_10 = ?, signature_11 = ?, signature_12 = ?, signature_13 = ?, signature_14 = ?, signature_15 = ?, signature_16 = ?, signature_17 = ?, signature_18 = ?, signature_19 = ?, signature_20 = ?, signature_formateur_1 = ?, signature_formateur_2 = ?, signature_formateur_3 = ?, signature_formateur_4 = ?, signature_formateur_5 = ?, signature_formateur_6 = ?, signature_formateur_7 = ?, signature_formateur_8 = ?, signature_formateur_9 = ?, signature_formateur_10 = ?, signature_formateur_11 = ?, signature_formateur_12 = ?, signature_formateur_13 = ?, signature_formateur_14 = ?, signature_formateur_15 = ?, signature_formateur_16 = ?, signature_formateur_17 = ?, signature_formateur_18 = ?, signature_formateur_19 = ?, signature_formateur_20 = ? WHERE nom_stagiaire LIKE ? AND prenom_stagiaire LIKE ?",
      array($signature1, $signature2, $signature3, $signature4, $signature5, $signature6, $signature7, $signature8, $signature9, $signature10, $signature11, $signature12, $signature13, $signature14, $signature15, $signature16, $signature17, $signature18, $signature19, $signature20, $signatureformateur1, $signatureformateur2, $signatureformateur3, $signatureformateur4, $signatureformateur5, $signatureformateur6, $signatureformateur7, $signatureformateur8, $signatureformateur9, $signatureformateur10, $signatureformateur11, $signatureformateur12, $signatureformateur13, $signatureformateur14, $signatureformateur15, $signatureformateur16, $signatureformateur17, $signatureformateur18, $signatureformateur19, $signatureformateur20, $nomstagiaire, $prenomstagiaire)
    );
    return $query;
  }

  function search_stagiaire($title){
    $this->db->like('nom_stagiaire', $title , 'both');
    $this->db->order_by('nom_stagiaire', 'ASC');
    $this->db->limit(20);
    return $this->db->get('Stagiaire')->result();
  }

  function search_formateur($title){
    $this->db->like('nom_formateur', $title , 'both');
    $this->db->order_by('nom_formateur', 'ASC');
    $this->db->limit(20);
    return $this->db->get('Formateurs')->result();
  }

