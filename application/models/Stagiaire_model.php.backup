      array($nom_stagiaire, $prenom_stagiaire, $nom_formateur, $prenom_formateur, $id_formation, $lieu_formation, $date_debut, $date_fin, $date_sign, $date_convention_1, $date_convention_2, $date_convention_3, $date_convention_4, $date_convention_5, $date_convention_6, $date_convention_7, $date_convention_8, $date_convention_9, $date_convention_10, $organisme, $nom_stagiaire, $prenom_stagiaire, $id_formation)
