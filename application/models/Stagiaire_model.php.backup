      "UPDATE Stagiaire SET prenom_stagiaire=?, nom_entreprise = ?, nom_commercial = ?, activite= ? , code_naf = ?, date_naissance = ?, numero_secu = ?, diplome = ?, mail= ?, numero_siret = ?, forme_juridique = ?, rue= ? , code_postal = ?, ville = ?, telephone = ?, num_accueil = ? WHERE nom_stagiaire LIKE ? AND prenom_stagiaire LIKE ?",
