  {
    $query = $this->db->query(
      "SELECT DISTINCT Formation.nom_formation FROM Convention, Formation WHERE Convention.id_formation = Formation.id_formation AND Formation.nom_thematique LIKE ? AND YEAR(Convention.date_debut) LIKE ?",
