  public function afficher_stagiairesss()
  {
    $query = $this->db->query("SELECT Stagiaire.*, acc.num_accueil, acc.nom_accueil, acc.interlocuteur, acc.adresse AS pt_adresse, acc.code_postal AS pt_code_postal, acc.ville AS pt_ville, acc.tel AS pt_tel, acc.mail AS pt_mail FROM Stagiaire INNER JOIN Accueil acc ON Stagiaire.num_accueil = acc.num_accueil");
    return $query->result();
  }

  public function calcul_formation($idf,$annee)
  {
    $s = 0;
    $query = $this->db->query(
      "SELECT prix_formation FROM Formation, Convention WHERE Formation.id_formation = Convention.id_formation AND Convention.id_formation LIKE ? AND YEAR(Convention.date_debut) LIKE ?",
      array($idf, $annee)
    );
    foreach ($query->result() as $row) {
      $s += $row->prix_formation;
    }
    return $s;
  }

