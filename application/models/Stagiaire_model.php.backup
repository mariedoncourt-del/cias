  public function convention_evaluation()
  {
    $query = $this->db->query("SELECT Convention.id_formation, evaluation_hot.nom_stagiaire, evaluation_hot.prenom_stagiaire FROM Convention, evaluation_hot WHERE Convention.nom_stagiaire = evaluation_hot.nom_stagiaire AND Convention.prenom_stagiaire = evaluation_hot.prenom_stagiaire");
    return $query->result();
  }

  public function nombre_formations($annee)
  {
    $query = $this->db->query(
      "SELECT COUNT(*) AS nombre FROM Convention, evaluation_hot WHERE Convention.nom_stagiaire = evaluation_hot.nom_stagiaire AND Convention.prenom_stagiaire = evaluation_hot.prenom_stagiaire AND YEAR(Convention.date_debut) LIKE ?",
      array($annee)
    );
    $data = '';
    foreach($query->result() as $row)
    {
      $data = $row->nombre;
    }
    return $data;
  }

  public function supprimer_evaluation_hot()
  {
    $query = $this->db->query("DELETE FROM evaluation_hot");
    return $query;
  }

  public function afficher_evaluation_hot($annee)
  {
    $query = $this->db->query(
      "SELECT evaluation_hot.* FROM evaluation_hot,Convention WHERE Convention.nom_stagiaire = evaluation_hot.nom_stagiaire AND Convention.prenom_stagiaire = evaluation_hot.prenom_stagiaire AND YEAR(Convention.date_debut) LIKE ?",
      array($annee)
    );
    $sat = 0;
    $total = 0;

    foreach($query->result() as $row)
    {
      $sat = $row->sati_1 + $row->sati_2 + $row->sati_3 + $row->sati_4 + $row->eval_1 + $row->eval_2 + $row->eval_3 + $row->eval_4 + $row->eval_5 + $row->eval_6 + $row->eval_7 + $row->eval_8;
      $tot = ($sat * 100)/48;
      $total += $tot;
    }

    return round($total/$this->nombre_formations($annee),2);
  }

  public function afficher_thematique($annee)
  {
    $query = $this->db->query(
      "SELECT nom_thematique FROM Formation,Convention WHERE Convention.id_formation = Formation.id_formation AND YEAR(Convention.date_debut) LIKE ? GROUP BY Formation.nom_thematique",
      array($annee)
    );
    return $query->result();
  }

  public function nombre_heure_par_theme($id_formation,$annee)
  {
    $tot = 0;
    $query = $this->db->query(
      "SELECT SUBSTR(Formation.duree_formation,1,2) AS duree FROM Formation,Convention WHERE Convention.id_formation = Formation.id_formation AND YEAR(Convention.date_debut) LIKE ? AND Formation.nom_thematique LIKE ? AND Convention.nom_stagiaire IS NOT NULL",
      array($annee, $id_formation)
    );
    foreach($query->result() as $row)
    {
      $tot = $tot + $row->duree;
    }
    return $tot;
  }

