  public function get_all_values($nom_formateur)
  {
    $datesColumns = ['date_convention_1', 'date_convention_2', 'date_convention_3', 'date_convention_4', 'date_convention_5','date_convention_6', 'date_convention_7', 'date_convention_8','date_convention_9','date_convention_10'];
    $this->db->select(implode(', ', $datesColumns));
    $this->db->from('Convention');
    $this->db->where('nom_formateur',$nom_formateur);

    $query = $this->db->get();
    $allDates = array();

    foreach ($query->result_array() as $row) {
      foreach ($datesColumns as $column) {
        $allDates[] = $row[$column];
      }
    }

    return $allDates;
  }

  public function verifier_convention($nom_formateur)
  {
    $this->db->select('nom_formateur, date_convention_6');
    $this->db->from('Convention');
    $this->db->where('nom_formateur', $nom_formateur);
    $this->db->group_by('nom_formateur, date_convention_6');
    $this->db->having('COUNT(*) > 1');
    
    $query = $this->db->get();
    return $query->result_array();
  }

  public function recherche_doublons_dates($nom_formateur)
  {
    $datesColumns = ['date_convention_1', 'date_convention_2', 'date_convention_3', 'date_convention_4', 'date_convention_5','date_convention_6', 'date_convention_7', 'date_convention_8','date_convention_9','date_convention_10'];

    $selectColumns = ['nom_formateur', 'prenom_formateur'];
    $selectColumns = array_merge($selectColumns, $datesColumns);

    $this->db->select(implode(', ', $selectColumns));
    $this->db->from('Convention');
    $this->db->where('nom_formateur', $nom_formateur);

    $data = $this->db->get()->result_array();
    $doublonsIndices = [];

    foreach ($datesColumns as $column) {
      $values = array_column($data, $column);
      $duplicates = array_keys(array_filter(array_count_values($values), function ($count) {
        return $count > 1;
      }));
      $doublonsIndices = array_merge($doublonsIndices, $duplicates);
    }

    $doublonsIndices = array_unique($doublonsIndices);
    return ['data' => $data, 'doublonsIndices' => $doublonsIndices];
  }

  public function recherche_colonne_doublons($nom_formateur)
  {
    $datesColumns = ['date_convention_1', 'date_convention_2', 'date_convention_3', 'date_convention_4', 'date_convention_5','date_convention_6', 'date_convention_7', 'date_convention_8','date_convention_9','date_convention_10'];

    $selectColumns = ['nom_formateur', 'prenom_formateur'];
    $selectColumns = array_merge($selectColumns, $datesColumns);

    $this->db->select(implode(', ', $selectColumns));
    $this->db->from('Convention');
    $this->db->where('nom_formateur', $nom_formateur);

    $data = $this->db->get()->result_array();
    $doublonsIndices = [];

    foreach ($datesColumns as $column) {
      $values = array_column($data, $column);
      $duplicates = array_keys(array_filter(array_count_values($values), function ($count) {
        return $count > 1;
      }));
      $doublonsIndices = array_merge($doublonsIndices, $duplicates);
    }

    $doublonsIndices = array_unique($doublonsIndices);
    return ['data' => $data, 'doublonsIndices' => $doublonsIndices];
  }

